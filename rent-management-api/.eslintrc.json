{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-console": "off",
    "consistent-return": "off",
    "no-bitwise": "off",
    "no-param-reassign": "off",
    "no-underscore-dangle": ["error", { "allow": ["_id"] }],
    "max-len": "off",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  }
}
