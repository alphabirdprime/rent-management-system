{
  "name": "rent-backend",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node ./bin/www",
    "start-dev": "NODE_ENV=dev node ./bin/www",
    "start-prod": "NODE_ENV=prod node ./bin/www",
    "start-e2e": "NODE_ENV=e2e_test node ./bin/www",
    "dev": "NODE_ENV=dev nodemon ./bin/www",
    "lint": "eslint --fix .",
    "test": "jest --verbose",
    "test:watch": "jest --coverage=false --watch"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "joi": "^17.13.3",
    "json-spec": "file:lib/json-spec",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js"
    ]
  }
}
